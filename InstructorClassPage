<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Course Management</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background-color: #f3f1ee;
      color: #222;
    }

    #navigation {
      background-color: white;
      border-bottom: 1px solid #ccc;
      box-shadow: 0 2px 5px rgba(0,0,0,0.08);
      padding: 0 30px;
    }

    #navbar {
      margin: 0;
      padding: 0;
      list-style: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 70px;
    }

    #nav-left {
      display: flex;
      align-items: center;
      gap: 15px;
      font-weight: bold;
      font-size: 18px;
    }

    #logo {
      height: 42px;
    }

    #nav-right {
      display: flex;
      align-items: center;
      gap: 35px;
    }

    #nav-right a {
      text-decoration: none;
      color: black;
      font-weight: 500;
    }

    .page-wrapper {
      width: 60%;
      margin: 50px auto;
    }

    .panel {
      background-color: white;
      border: 1px solid #444;
      border-radius: 14px;
      padding: 30px;
      margin-bottom: 25px;
    }

    h1, h2, h3 {
      margin-top: 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
      margin-bottom: 20px;
    }

    th, td {
      border: 1px solid #ccc;
      padding: 12px;
      text-align: left;
    }

    .btn {
      display: inline-block;
      background-color: #f4ae2b;
      color: white;
      text-decoration: none;
      padding: 12px 18px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      font-weight: bold;
      margin-right: 10px;
    }
  </style>
</head>
<body>

  <div id="navigation">
    <ul id="navbar">
      <li id="nav-left">
        <img src="logo.png" id="logo" alt="logo">
        <span>Instructor John Doe</span>
      </li>

      <li id="nav-right">
        <a href="instructorDashboard2.html">Home</a>
        <a href="InstructorCreateClassPage.html">Add a class</a>
        <a href="InstructorClassPage3.html">Courses management</a>
      </li>
    </ul>
  </div>

  <div class="page-wrapper">
    <div class="panel">
      <h1 id="course-title">Course Management</h1>
      <p><strong>Term:</strong> Winter 2026</p>
    </div>

    <div class="panel">
      <h2>Assessment Categories and Weight</h2>
      <table>
        <tr>
          <th>Category</th>
          <th>Weight (%)</th>
        </tr>
        <tr>
          <td>Assignments</td>
          <td>10</td>
        </tr>
        <tr>
          <td>Midterm</td>
          <td>40</td>
        </tr>
        <tr>
          <td>Final</td>
          <td>50</td>
        </tr>
      </table>

      <button class="btn" type="button">Add Category</button>
      <button class="btn" type="button">Edit Weights</button>
    </div>

    <div class="panel">
      <h2>Course Status</h2>
      <p>This course is currently enabled.</p>
      <button class="btn" type="button">Disable Course</button>
    </div>

    <div class="panel">
      <h2>Usage Statistics</h2>
      <p>Students completed assessments: 73%</p>
      <p>Students entered grades: 62%</p>
    </div>
  </div>

  <script>
    const courseId = localStorage.getItem("courseId");
    const title = document.getElementById("course-title");

    if (courseId === "course1") {
      title.innerHTML = "SOEN 287 - Web Programming";
    } else if (courseId === "course2") {
      title.innerHTML = "MAST 218 - Multivariable Calculus";
    } else if (courseId === "course3") {
      title.innerHTML = "COMP 233 - Statistics";
    } else if (courseId === "course4") {
      title.innerHTML = "COMP 345 - Data Analysis";
    }
  </script>

</body>
</html>
